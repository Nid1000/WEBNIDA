# Copia este archivo como `.env` y completa los valores segun tu entorno.

# Base de datos (ejemplo MySQL)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/delicias_bakery"

# JWT y otros secretos usados por la API
JWT_SECRET=""
DECOLECTA_TOKEN=""

# Configuracion de archivos
UPLOAD_PATH="uploads/"
MAX_FILE_SIZE=5242880

